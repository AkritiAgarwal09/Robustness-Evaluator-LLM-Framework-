# ════════════════════════════════════════════════════════════════════════════
#  LLM Robustness Framework — Environment Configuration
#  Copy this to .env and fill in your values.
# ════════════════════════════════════════════════════════════════════════════

# ── Inference backend ─────────────────────────────────────────────────────────
# "ollama"  → local Ollama server  (recommended, zero-cost)
# "vllm"    → local vLLM server    (GPU, high-throughput)
# "mock"    → synthetic responses  (demo, no model needed)
# "openai"  → OpenAI cloud         (optional fallback)
INFERENCE_BACKEND=ollama

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Models you have pulled via `ollama pull <model>`
# Comma-separated list — these will appear in the dashboard
OLLAMA_MODELS=llama3,mistral,mistral:7b,codellama,llama3:70b

# ── vLLM (optional, GPU) ──────────────────────────────────────────────────────
VLLM_BASE_URL=http://localhost:8001
# VLLM_MODELS=meta-llama/Meta-Llama-3-8B-Instruct,mistralai/Mistral-7B-Instruct-v0.2

# ── Cloud fallbacks (optional) ────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Evaluation defaults ───────────────────────────────────────────────────────
DEFAULT_NUM_VARIANTS=5
DEFAULT_MAX_TOKENS=512
DEFAULT_TEMPERATURE=0.0        # 0.0 for deterministic reasoning evals
INFERENCE_CONCURRENCY=4        # parallel requests per model

# ── Persistence ───────────────────────────────────────────────────────────────
DB_PATH=./data/results.duckdb

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
